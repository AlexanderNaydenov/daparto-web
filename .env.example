# Hygraph Content API (POST GraphQL to this URL)
HYGRAPH_ENDPOINT=https://eu-central-1-shared-euc1-02.cdn.hygraph.com/content/cmnfzi49100b507ulrzqhjccv/master

# Click-to-edit (@hygraph/preview-sdk) — must match HYGRAPH_ENDPOINT; exposed to the browser
NEXT_PUBLIC_HYGRAPH_ENDPOINT=https://eu-central-1-shared-euc1-02.cdn.hygraph.com/content/cmnfzi49100b507ulrzqhjccv/master

# Hygraph Studio base URL (no trailing slash). Project settings → API Access → Studio URL, or https://app.hygraph.com
NEXT_PUBLIC_HYGRAPH_STUDIO_URL=https://app.hygraph.com

# Production (published) — read token for ISR + cache tags (set in Vercel as HYGRAPH_PRODUCTION)
HYGRAPH_PRODUCTION=

# Preview / draft — Live Preview + DRAFT stage (set in Vercel as HYGRAPH_PREVIEW_TOKEN)
HYGRAPH_PREVIEW_TOKEN=

# Legacy single token (optional fallback if the split tokens above are unset)
HYGRAPH_API_TOKEN=

# Secret for /api/draft?secret=… — must match Hygraph Preview widget URL (generate a long random string)
HYGRAPH_PREVIEW_SECRET=

# Secret for /api/revalidate — Hygraph webhook or manual purge of tagged cache (generate a long random string)
REVALIDATE_SECRET=
