# Hygraph Content API (POST GraphQL to this URL)
HYGRAPH_ENDPOINT=https://eu-central-1-shared-euc1-02.cdn.hygraph.com/content/cmnfzi49100b507ulrzqhjccv/master

# Optional but often required: Permanent Auth Token with read access to the models you query.
# Create in Hygraph: Project settings → API Access → Permanent Auth Tokens
# Add this in Vercel as HYGRAPH_API_TOKEN (server-only; never NEXT_PUBLIC_*).
HYGRAPH_API_TOKEN=
